{
  "name": "kurrentdb-adapter",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "generate": "protoc --proto_path=./proto/Grpc --ts_proto_out=./src/interfaces ./proto/Grpc/*.proto --ts_proto_opt=nestJs=true",
    "build": "nest build",
    "container:build": "docker build -t kurrentdb-adapter:local .",
    "container:run": "docker run --rm -p 2113:2113 kurrentdb-adapter:local",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:env": "docker compose up -d postgres kurrentdb && npm run start:dev",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "kurrentdb:up": "docker compose up -d kurrentdb",
    "dev:up": "docker compose up -d postgres kurrentdb",
    "dev:down": "docker compose down",
    "playground:append-read": "ts-node playground/append-and-read.ts",
    "bench:append": "ts-node playground/append-throughput.ts",
    "bench:append:matrix": "ts-node playground/append-benchmark-matrix.ts",
    "playground:subscribe-all": "ts-node playground/subscribe-all.ts",
    "playground:filtered-read": "ts-node playground/filtered-read.ts",
    "playground:stream-metadata": "ts-node playground/stream-metadata.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json test/streams.e2e-spec.ts test/scavenge.e2e-spec.ts test/read-validation.e2e-spec.ts test/kurrentdb.e2e-spec.ts test/scavenge-kurrentdb.e2e-spec.ts test/read-validation-kurrentdb.e2e-spec.ts",
    "test:e2e:adapter": "jest --config ./test/jest-e2e.json test/streams.e2e-spec.ts test/scavenge.e2e-spec.ts test/read-validation.e2e-spec.ts",
    "test:e2e:kurrentdb": "jest --config ./test/jest-e2e.json test/kurrentdb.e2e-spec.ts test/scavenge-kurrentdb.e2e-spec.ts test/read-validation-kurrentdb.e2e-spec.ts",
    "test:e2e:contracts": "jest --config ./test/jest-e2e.json",
    "bench:report": "ts-node benchmark/run.ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.13.4",
    "@grpc/proto-loader": "^0.7.15",
    "@kurrent/kurrentdb-client": "^1.0.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.3",
    "@nestjs/platform-express": "^11.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ts-proto": "^2.7.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "prettier-eslint": "^16.4.2",
    "protoc": "^1.1.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "^11.13.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
